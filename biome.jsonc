{
	"files": {
		"includes": ["src/**/*"]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"css": {
		"linter": {
			"enabled": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	},
	"overrides": [
		{
			"includes": ["**/*.module.css"],
			"linter": {
				"rules": {
					"correctness": {
						/**
						 *  biome correctly identifies :global and :local as valid CSS module pseudo-classes but the
						 *  LSP (used by the IDE) does not
						 */
						"noUnknownPseudoClass": {
							"level": "error",
							"options": {
								"ignore": ["global", "local"]
							}
						}
					}
				}
			}
		}
	],
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							"server-only",
							":BLANK_LINE:",
							{
								"type": false,
								"source": ["next", "next/**", "react", "react-dom"]
							},
							":BLANK_LINE:",
							{
								"type": false,
								"source": ["node:*"]
							},
							":BLANK_LINE:",
							{
								"type": false,
								"source": ["@*/**", "!@/**"]
							},
							":BLANK_LINE:",
							":PACKAGE:",
							":BLANK_LINE:",
							":ALIAS:",
							":BLANK_LINE:",
							":PATH:"
						]
					}
				}
			}
		}
	}
}
